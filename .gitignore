node_modules/
dist/
coverage/
.data/
.DS_Store
npm-debug.log*

# Secrets — never commit real env files
.env
.env.*
!.env.example

# SSH private keys
*.pem
*.key

CLAUDE.md
.claude/

# Local .terraform directories
**/.terraform/*

# .tfstate files (These can contain sensitive data and should NOT be in git)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and not
# intended to be committed
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc