# ── Copy to .env and fill in. Never commit .env. ──────────────────────────────

# Postgres (used by both the db and app containers)
POSTGRES_USER=lt
POSTGRES_PASSWORD=change-me-to-a-long-random-password
POSTGRES_DB=learning_tracker

# Public URL users visit. Local: http://localhost:8080  Prod: https://your.domain.com
# Google OAuth redirect URI must be exactly: ${APP_BASE_URL}/auth/google/callback
APP_BASE_URL=http://localhost:8080

# Session cookie signing secret, >= 32 chars. Generate: openssl rand -hex 32
SESSION_SECRET=

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials → Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated Google emails seeded as admins on boot
ADMIN_EMAILS=you@gmail.com

# Set true once the site is served over HTTPS (production). false for http://localhost.
COOKIE_SECURE=false

# Host port nginx publishes in the default (non-TLS) compose file
WEB_PORT=8080

# Local testing only — never true in production
DEV_LOGIN_ENABLED=false
