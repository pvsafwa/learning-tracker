# Copy to .env and fill in. Never commit your real .env.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4173
# Public base URL of the app. No trailing slash. Used to build the OAuth callback.
APP_BASE_URL=http://localhost:4173
# Long random string for signing session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── Content (data tier: media volume) ─────────────────────────────────────────
# Folder on the server that holds your course folders.
COURSES_DIR=./courses

# ── Database (data tier: PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgres://lt:lt_password@localhost:5432/learning_tracker

# ── Google OAuth (auth) ───────────────────────────────────────────────────────
# Create an OAuth client (type "Web application") at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI MUST be exactly:  ${APP_BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Comma-separated Google emails seeded as admins on startup, so the first
# admin can sign in immediately and manage the allowlist from the admin page.
ADMIN_EMAILS=you@gmail.com

# ── Local testing only ────────────────────────────────────────────────────────
# When true AND NODE_ENV!=production, enables POST /auth/dev to log in WITHOUT
# Google (for local/CI testing of the pipeline). NEVER enable in production.
DEV_LOGIN_ENABLED=false
